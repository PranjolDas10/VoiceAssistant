# ─────────────────────────────────────────────────────────────────────────────
# ARIA Voice Assistant — Environment Configuration Template
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Download client_secret.json from Google Cloud Console → OAuth 2.0 Credentials
# Enable: Google Calendar API, Gmail API
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Free tier at https://openweathermap.org/api
OPENWEATHER_KEY=your_openweathermap_api_key_here

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Free tier at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── Wolfram Alpha ─────────────────────────────────────────────────────────────
# Free developer key at https://developer.wolframalpha.com/
WOLFRAM_APP_ID=your_wolfram_app_id_here

# ── Gmail (for sending email via SMTP) ───────────────────────────────────────
# Use an App Password, NOT your main Gmail password.
# Enable 2FA, then create App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
DEFAULT_EMAIL_TO=recipient@example.com

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Sign up at https://www.twilio.com — free trial includes test credits
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+1XXXXXXXXXX

# ── Local Paths ───────────────────────────────────────────────────────────────
# Customize these to match your system's install locations
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
WORD_PATH=C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE
EXCEL_PATH=C:\Program Files\Microsoft Office\root\Office16\EXCEL.EXE
VSCODE_PATH=C:\Users\YOUR_USERNAME\AppData\Local\Programs\Microsoft VS Code\Code.exe
MUSIC_DIR=C:\Users\YOUR_USERNAME\Music
WALLPAPER_DIR=C:\Users\YOUR_USERNAME\Pictures\Wallpapers

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
